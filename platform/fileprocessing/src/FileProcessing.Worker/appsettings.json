{
  "Messaging": {
    "MessageBroker": "RabbitMQ"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "NServiceBus": "Information"
    }
  },
  
  "CosmosDb": {
    "DatabaseName": "file-processing",
    "Containers": {
      "Configurations": "file-processing-configurations",
      "Executions": "file-processing-executions",
      "DiscoveredFiles": "file-processing-discovered-files"
    },
    "FileProcessingConfigsEncryptionKeyName": "file-processing-dek"
  },

  "BlobStorage": {
    "ContainerNameForDownloadedFiles": "RiskInsureFileProcessing",
    "DefaultFileExpirationInDays": 7
  },
  
  "ConnectionStrings": {
    "RabbitMQ": "host=localhost;username=guest;password=guest",
    "ServiceBus": "",
    "CosmosDb": "",
    "BlobStorage": ""
  },
  
  "AzureKeyVault": {
    "VaultUri": "https://REPLACE_WITH_KEYVAULT_NAME.vault.azure.net/",
    "UsingEmulator": false
  },
  
  "Scheduler": {
    "PollingIntervalSeconds": 60,
    "ExecutionWindowMinutes": 2,
    "MaxConcurrentChecks": 100,
    "EnableDistributedLocking": true
  },
  
  "ProtocolDefaults": {
    "Ftp": {
      "ConnectionTimeoutSeconds": 30,
      "DataConnectionTimeoutSeconds": 60,
      "RetryAttempts": 3,
      "RetryDelaySeconds": 5
    },
    "Https": {
      "TimeoutSeconds": 30,
      "RetryAttempts": 3,
      "RetryDelaySeconds": 5
    },
    "AzureBlob": {
      "TimeoutSeconds": 30,
      "RetryAttempts": 3,
      "RetryDelaySeconds": 5
    }
  }
}

