{
  "Messaging": {
    "MessageBroker": "RabbitMQ"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "NServiceBus": "Information"
    }
  },
  "AllowedHosts": "*",
  
  "CosmosDb": {
    "DatabaseName": "file-processing",
    "Containers": {
      "Configurations": "file-processing-configurations",
      "Executions": "file-processing-executions",
      "DiscoveredFiles": "file-processing-discovered-files"
    },
    "FileProcessingConfigsEncryptionKeyName": "file-processing-configs-dek"
  },
  
  "ConnectionStrings": {
    "RabbitMQ": "host=localhost;username=guest;password=guest",
    "ServiceBus": "",
    "CosmosDb": ""
  },
  
  "AzureKeyVault": {
    "VaultUri": "https://REPLACE_WITH_KEYVAULT_NAME.vault.azure.net/",
    "UsingEmulator": false
  },
  
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_SECRET_KEY_AT_LEAST_32_CHARS_LONG_FOR_PRODUCTION",
    "Issuer": "https://riskinsure.com",
    "Audience": "file-processing-api",
    "ExpirationMinutes": 60
  },
  
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5001",
      "https://REPLACE_WITH_FRONTEND_URL"
    ]
  },
  
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  }
}

