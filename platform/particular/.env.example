# Copy this file to .env and fill values. Do NOT commit your .env file.

# Message transport (Azure Service Bus emulator or Azure SB)
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://<your-namespace>.servicebus.windows.net/;SharedAccessKeyName=<name>;SharedAccessKey=<key>

# Particular license (if you have one). Multi-line license should be provided as the full contents.
PARTICULARSOFTWARE_LICENSE="<paste-your-particular-license-here>"

# Optional: RavenDB settings if using an external RavenDB service.
# If using the included `ravendb` service in the compose, the RAVENDB_CONNECTIONSTRING is set automatically.
RAVENDB_CONNECTIONSTRING=http://ravendb:8080
