SQL_PASSWORD=P@ssw0rd123!

# HTTP port for Management & Health-check APIs
EMULATOR_HTTP_PORT=5300

# Path to the Service Bus configuration file (relative to docker-compose.yml)
CONFIG_PATH=./config.json
