{
  "Messaging":
  {
    "MessageBroker": "",
    "AzureServiceBus": {
      "UseWebSockets": true,
      "TryTimeoutSeconds": 10,
      "MaxRetries": 2
    }
  },
  "ConnectionStrings": {
    "CosmosDb": "",
    "RabbitMQ": "",
    "ServiceBus": ""
  },
  "CosmosDb": {
    "DatabaseName": "RiskInsure",
    "ContainerName": "riskratingandunderwriting"
  },
  "Telemetry": {
    "EnableAzureSdkEventSourceVerbose": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "NServiceBus": "Debug",
      "NServiceBus.Transport.AzureServiceBus": "Debug",
      "Azure.Messaging.ServiceBus": "Debug",
      "Azure.Core": "Information",
      "OpenTelemetry": "Information",
      "RiskInsure.RiskRatingAndUnderwriting.Domain.Managers.RiskQuoteManager": "Debug"
    }
  },
  "AllowedHosts": "*"
}
